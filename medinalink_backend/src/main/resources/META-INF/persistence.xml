<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="medinalinkPU" transaction-type="JTA">

        <jta-data-source>java:jboss/datasources/MedinalinkDS</jta-data-source>

        <class>ma.medinalink.entity.User</class>
        <class>ma.medinalink.entity.Commune</class>
        <class>ma.medinalink.entity.Report</class>
        <class>ma.medinalink.entity.PublicPriority</class>
        <class>ma.medinalink.entity.AiInteraction</class>

        <properties>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>
        </properties>
    </persistence-unit>

</persistence>