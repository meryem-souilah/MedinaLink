# ╔══════════════════════════════════════════════════════════════╗
# ║          MedinaLink — Variables d'environnement             ║
# ║  Copie ce fichier en .env et remplis les valeurs réelles    ║
# ║  Ne committe JAMAIS le fichier .env dans Git                ║
# ╚══════════════════════════════════════════════════════════════╝

# ── PostgreSQL (dev local uniquement) ─────────────────────────────
POSTGRES_DB=medinalink
POSTGRES_USER=medinalink
POSTGRES_PASSWORD=change_me_in_production

# ── Backend WildFly ───────────────────────────────────────────────
# DB_URL en prod Neon : jdbc:postgresql://ep-xxx.neon.tech/medinalink?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/medinalink
DB_USER=medinalink
DB_PASSWORD=change_me_in_production

# JWT : clé secrète longue et aléatoire (min. 32 caractères)
MEDINALINK_JWT_SECRET=change_me_to_a_very_long_random_secret_key_minimum_32_chars

# ── Redis (Upstash en prod) ───────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AI Microservice ───────────────────────────────────────────────
# En dev local : http://localhost:5001
# En prod Railway : https://medinalink-ai.up.railway.app
AI_SERVICE_URL=http://localhost:5001

# ── Groq API — obtenir sur https://console.groq.com/keys ─────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── Frontend (Vite — injecté au BUILD, pas au runtime) ───────────
# En prod : https://medinalink-backend.up.railway.app/medinalink/api/v1
VITE_API_URL=http://localhost:8080/medinalink/api/v1
VITE_WS_URL=ws://localhost:8080/medinalink
